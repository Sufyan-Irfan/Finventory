<!DOCTYPE html>
<html lang="en">
<head>
  <title>FINVENTORY</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    :root {
      --sidebar-width: 185px;
      --topbar-height: 60px;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: #f8f9fa;
      overflow-x: hidden;
    }

    /* ===================== SIDEBAR ===================== */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      height: 100vh;
      width: var(--sidebar-width);
      background: #343a40;
      padding-top: 20px;
      overflow-y: auto;
      z-index: 1040;
      transition: transform 0.3s ease;
    }

    .sidebar a {
      color: #fff;
      text-decoration: none;
      padding: 10px 20px;
      display: block;
    }

    .sidebar a:hover { background: #495057; }

    .sidebar .dropdown-menu {
      background: #2c2f33 !important;
      border-radius: 6px;
    }

    .sidebar .dropdown-item {
      color: #fff;
      padding-left: 1.5rem;
    }

    .sidebar .dropdown-item:hover { background: #495057 !important; }

    /* Mobile: sidebar hidden by default */
    @media (max-width: 768px) {
      .sidebar {
        transform: translateX(-100%);
      }
      .sidebar.open {
        transform: translateX(0);
      }
    }

    /* ===================== OVERLAY ===================== */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 1035;
    }
    .sidebar-overlay.show { display: block; }

    /* ===================== TOPBAR ===================== */
    .topbar {
      position: fixed;
      top: 0;
      left: var(--sidebar-width);
      right: 0;
      height: var(--topbar-height);
      background: #fff;
      border-bottom: 1px solid #dee2e6;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      z-index: 1020;
      transition: left 0.3s ease;
      gap: 8px;
    }

    @media (max-width: 768px) {
      .topbar {
        left: 0;
      }
    }

    /* ===================== MAIN CONTENT ===================== */
    .main-content {
      margin-left: var(--sidebar-width);
      margin-top: var(--topbar-height);
      padding: 20px;
      min-height: 100vh;
      background: #f8f9fa;
      transition: margin-left 0.3s ease;
    }

    @media (max-width: 768px) {
      .main-content {
        margin-left: 0;
      }
    }

    /* ===================== TOPBAR ITEMS ===================== */
    .time-date {
      font-size: 0.82rem;
      color: #6c757d;
      white-space: nowrap;
    }

    /* Hide date/time on very small screens */
    @media (max-width: 480px) {
      .time-date { display: none; }
      .search-box { width: 110px !important; }
    }

    .topbar-left {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .topbar-right {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* Hamburger button */
    .hamburger-btn {
      display: none;
      background: #f1f3f5;
      border: 1px solid #ced4da;
      border-radius: 5px;
      padding: 6px 10px;
      cursor: pointer;
      font-size: 1.1rem;
      line-height: 1;
    }

    @media (max-width: 768px) {
      .hamburger-btn { display: block; }
    }

    .calculator-btn {
      background: #f1f3f5;
      border: 1px solid #ced4da;
      border-radius: 5px;
      padding: 6px 10px;
      cursor: pointer;
      transition: 0.2s;
      white-space: nowrap;
      font-size: 0.9rem;
    }

    .calculator-btn:hover { background: #e9ecef; }

    /* ===================== CALCULATOR ===================== */
    .calculator-popup {
      position: absolute;
      top: 65px;
      left: 200px;
      background: #fff;
      border: 1px solid #ddd;
      display: none;
      z-index: 1100;
      width: 250px;
      border-radius: 6px;
    }

    @media (max-width: 768px) {
      .calculator-popup {
        left: 10px;
        right: 10px;
        width: auto;
      }
    }

    .calculator-display {
      width: 100%;
      height: 50px;
      text-align: right;
      padding: 8px;
      font-size: 1.3rem;
      border: none;
      background: #f8f9fa;
      border-radius: 4px;
    }

    .calc-container {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .calc-btn {
      height: 45px;
      font-size: 1rem;
      border: none;
      border-radius: 5px;
      background: #e9ecef;
      transition: 0.2s;
      cursor: pointer;
    }

    .calc-btn:hover { background: #d6d8db; }
    .calc-btn.operator { background: #dee2e6; }
    .calc-btn.operator:hover { background: #ced4da; }
    .calc-btn.equal { background: #0d6efd; color: white; }
    .calc-btn.equal:hover { background: #0b5ed7; }

    /* ===================== SIDEBAR CLOSE BTN ===================== */
    .sidebar-close {
      display: none;
      position: absolute;
      top: 12px;
      right: 12px;
      background: transparent;
      border: none;
      color: #adb5bd;
      font-size: 1.3rem;
      cursor: pointer;
      line-height: 1;
    }

    @media (max-width: 768px) {
      .sidebar-close { display: block; }
    }
  </style>
</head>

<body>

  <!-- Overlay for mobile -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- 📘 Sidebar -->
  <div class="sidebar" id="sidebar">
    <button class="sidebar-close" id="sidebarClose"><i class="bi bi-x-lg"></i></button>
    <h5 class="text-white text-center mb-3 mt-1">💼 FINVENTORY</h5>

    <a href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a>

    <!-- Account Settings -->
    <div class="dropdown">
      <a href="#" class="dropdown-toggle text-white px-3 py-2 d-flex justify-content-between align-items-center"
        data-bs-toggle="dropdown">
        <span><i class="bi bi-person-plus"></i> Account Settings</span>
      </a>
      <ul class="dropdown-menu dropdown-menu-dark border-0 shadow w-100 ms-3">
        <li><a class="dropdown-item" href="/gl/groups">Manage Groups</a></li>
        <li><a class="dropdown-item" href="/gl/accounts">Manage Accounts</a></li>
        <li><a class="dropdown-item" href="/gl/chart">Chart Of Accounts</a></li>
      </ul>
    </div>

    <!-- Transactions -->
    <div class="dropdown">
      <a href="#" class="dropdown-toggle text-white px-3 py-2 d-flex justify-content-between align-items-center"
        data-bs-toggle="dropdown">
        <span><i class="bi bi-journal-plus"></i> Transactions</span>
      </a>
      <ul class="dropdown-menu dropdown-menu-dark border-0 shadow w-100 ms-3">
        <li><a class="dropdown-item" href="/gl/add-transaction?type=receipt">Receipt Voucher</a></li>
        <li><a class="dropdown-item" href="/gl/add-transaction?type=payment">Payment Voucher</a></li>
      </ul>
    </div>

    <!-- Reports -->
    <div class="dropdown">
      <a href="#" class="dropdown-toggle text-white px-3 py-2 d-flex justify-content-between align-items-center"
        data-bs-toggle="dropdown">
        <span><i class="bi bi-file-text"></i> Reports</span>
      </a>
      <ul class="dropdown-menu dropdown-menu-dark border-0 shadow w-100 ms-3">
        <li><a class="dropdown-item" href="/trial-balance">Trial Balance</a></li>
        <li><a class="dropdown-item" href="/cash-book">Cash Book</a></li>
        <li><a class="dropdown-item" href="/report">GL Transactions</a></li>
        <li><a class="dropdown-item" href="/daily-posting">📋 Daily Posting</a></li>
      </ul>
    </div>

    <a href="/setup/settings"><i class="bi bi-gear"></i> Setup</a>

    <% if (currentUser && currentUser.role === 'admin') { %>
      <a href="/users"><i class="bi bi-people"></i> Manage Users</a>
    <% } %>
  </div>

  <!-- 📋 Topbar -->
  <div class="topbar">
    <div class="topbar-left">
      <!-- Hamburger — only mobile -->
      <button class="hamburger-btn" id="hamburgerBtn">
        <i class="bi bi-list"></i>
      </button>

      <div class="fw-semibold" style="font-size:0.9rem;">
        <i class="bi bi-person-circle"></i>
        <% if (currentUser) { %>
          <span><%= currentUser.username %></span>
        <% } else { %>
          Guest
        <% } %>
      </div>

      <!-- Calculator -->
      <div class="calculator-btn" id="calcToggleBtn">
        <i class="bi bi-calculator"></i>
      </div>

      <!-- Day Summary -->
      <a href="/daily-posting" class="calculator-btn text-decoration-none text-dark">
        <i class="bi bi-calendar-check"></i>
        <span class="d-none d-sm-inline"> Day Summary</span>
      </a>

      <!-- Date & Time -->
      <div class="time-date d-none d-md-block">
        <span id="currentDate"></span> | <span id="currentTime"></span>
      </div>
    </div>

    <div class="topbar-right">
      <!-- Search -->
      <input type="text" id="searchInput" class="form-control form-control-sm search-box"
        style="width:160px;" placeholder="🔍 Search">

      <!-- User / Company dropdown -->
      <% if (currentUser) { %>
        <div class="dropdown">
          <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
            data-bs-toggle="dropdown">
            <%= currentUser.company_code %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end shadow">
            <li><a class="dropdown-item text-danger" href="/logout">
              <i class="bi bi-box-arrow-right"></i> Logout
            </a></li>
          </ul>
        </div>
      <% } %>
    </div>
  </div>

  <!-- 📄 Main Content -->
  <div class="main-content">
    <%- body %>
  </div>

  <!-- Calculator Popup -->
  <div id="calculatorPopup" class="calculator-popup shadow p-2 rounded">
    <input type="text" id="calcDisplay" class="calculator-display" readonly>
    <div class="calc-container mt-2">
      <button class="calc-btn">(</button>
      <button class="calc-btn">)</button>
      <button class="calc-btn">%</button>
      <button class="calc-btn operator text-danger" onclick="clearCalc()">CE</button>

      <button class="calc-btn">7</button>
      <button class="calc-btn">8</button>
      <button class="calc-btn">9</button>
      <button class="calc-btn operator">/</button>

      <button class="calc-btn">4</button>
      <button class="calc-btn">5</button>
      <button class="calc-btn">6</button>
      <button class="calc-btn operator">*</button>

      <button class="calc-btn">1</button>
      <button class="calc-btn">2</button>
      <button class="calc-btn">3</button>
      <button class="calc-btn operator">-</button>

      <button class="calc-btn">0</button>
      <button class="calc-btn">.</button>
      <button class="calc-btn equal">=</button>
      <button class="calc-btn operator">+</button>
    </div>
  </div>

  <!-- JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

  <script>
    // ===================== HAMBURGER =====================
    const sidebar        = document.getElementById('sidebar');
    const overlay        = document.getElementById('sidebarOverlay');
    const hamburgerBtn   = document.getElementById('hamburgerBtn');
    const sidebarClose   = document.getElementById('sidebarClose');

    function openSidebar() {
      sidebar.classList.add('open');
      overlay.classList.add('show');
    }

    function closeSidebar() {
      sidebar.classList.remove('open');
      overlay.classList.remove('show');
    }

    hamburgerBtn.addEventListener('click', openSidebar);
    sidebarClose.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);

    // Close sidebar on nav link click (mobile)
    sidebar.querySelectorAll('a:not(.dropdown-toggle)').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) closeSidebar();
      });
    });

    // ===================== CALCULATOR =====================
    const calcPopup   = document.getElementById('calculatorPopup');
    const calcDisplay = document.getElementById('calcDisplay');
    const calcToggle  = document.getElementById('calcToggleBtn');

    calcToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      calcPopup.style.display = calcPopup.style.display === 'block' ? 'none' : 'block';
    });

    document.addEventListener('click', (e) => {
      if (!calcPopup.contains(e.target) && e.target !== calcToggle && !calcToggle.contains(e.target)) {
        calcPopup.style.display = 'none';
      }
    });

    calcPopup.querySelectorAll('.calc-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.textContent.trim();
        if (val === 'CE')     clearCalc();
        else if (val === '=') calculate();
        else                  calcDisplay.value += val;
      });
    });

    function clearCalc()  { calcDisplay.value = ''; }
    function calculate()  {
      try   { calcDisplay.value = eval(calcDisplay.value) || ''; }
      catch { calcDisplay.value = 'Error'; }
    }

    // ===================== DATE & TIME =====================
    function updateDateTime() {
      const now  = new Date();
      document.getElementById('currentDate').textContent = now.toLocaleDateString('en-GB');
      document.getElementById('currentTime').textContent = now.toLocaleTimeString();
    }
    setInterval(updateDateTime, 1000);
    updateDateTime();

    // ===================== SEARCH =====================
    $('#searchInput').on('keypress', function(e) {
      if (e.which === 13) {
        const q = $(this).val().trim();
        if (q) window.location.href = `/search?query=${q}`;
      }
    });
  </script>
</body>
</html>
