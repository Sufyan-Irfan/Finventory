<!DOCTYPE html>
<html>
<head>
  <title>Trial Balance Result</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h4>Trial Balance (Group Wise)</h4>
        <div>Period: <strong><%= start_date %></strong> → <strong><%= end_date %></strong></div>
      </div>
      <div class="text-end">
        <div class="fw-semibold"><%= company_code %></div>
        <div class="mt-2">
          <button class="btn btn-outline-dark btn-sm me-2" onclick="exportToPDF()">📄 PDF</button>
          <button class="btn btn-outline-success btn-sm" onclick="exportExcel()">📊 Excel</button>
        </div>
      </div>
    </div>

    <table class="table table-bordered table-sm">
      <thead class="table-light">
        <tr>
          <th>S.No</th>
          <th>Code</th>
          <th>Name</th>
          <th class="text-end">Debit</th>
          <th class="text-end">Credit</th>
        </tr>
      </thead>
      <tbody>

        <% groups.forEach(g => { %>

          <!-- GROUP HEADER -->
          <tr class="table-secondary fw-bold">
            <td></td>
            <td><%= g.group_code %></td>
            <td><%= g.group_name %></td>
            <td></td>
            <td></td>
          </tr>

          <!-- ACCOUNTS -->
          <% g.accounts.forEach(a => { %>
            <tr>
              <td class="ps-4"><%= a.sno %></td>
              <td class="ps-4"><%= a.account_code %></td>
              <td class="ps-4"><%= a.account_name %></td>
              <td class="text-end"><%= a.debit > 0 ? Number(a.debit).toFixed(2) : '' %></td>
              <td class="text-end"><%= a.credit > 0 ? Number(a.credit).toFixed(2) : '' %></td>
            </tr>
          <% }) %>

          <!-- GROUP TOTAL -->
          <tr class="fw-bold bg-light">
            <td colspan="3" class="text-end">Group Total</td>
            <td class="text-end"><%= g.total_debit.toFixed(2) %></td>
            <td class="text-end"><%= g.total_credit.toFixed(2) %></td>
          </tr>

          <tr class="fw-bold text-danger">
            <td colspan="3" class="text-end">Difference</td>
            <td colspan="2" class="text-end"><%= g.difference.toFixed(2) %></td>
          </tr>

        <% }) %>

        <!-- GRAND TOTAL -->
        <tr class="fw-bold table-dark">
          <td colspan="3" class="text-end">Grand Total</td>
          <td class="text-end"><%= grand.debit.toFixed(2) %></td>
          <td class="text-end"><%= grand.credit.toFixed(2) %></td>
        </tr>

        <tr class="fw-bold text-warning">
          <td colspan="3" class="text-end">Difference</td>
          <td colspan="2" class="text-end"><%= grand.difference.toFixed(2) %></td>
        </tr>

      </tbody>
    </table>

    <a href="/trial-balance" class="btn btn-link">← Back</a>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

  <script>
    const report = <%- JSON.stringify({ groups, grand, start_date, end_date, company_code }) %>;

    /* ===================== EXCEL ===================== */
    function exportExcel() {
      const sheet = [];
      sheet.push(['Trial Balance']);
      sheet.push([report.company_code]);
      sheet.push([`${report.start_date} - ${report.end_date}`]);
      sheet.push([]);
      sheet.push(['S.No', 'Code', 'Name', 'Debit', 'Credit']);

      report.groups.forEach(g => {
        // Group header
        sheet.push(['', g.group_code, g.group_name, '', '']);

        // Accounts
        g.accounts.forEach(a => {
          sheet.push([
            a.sno,
            a.account_code,
            a.account_name,
            a.debit ? Number(a.debit).toFixed(2) : '',
            a.credit ? Number(a.credit).toFixed(2) : ''
          ]);
        });

        // Group total
        sheet.push(['', '', 'Group Total', Number(g.total_debit).toFixed(2), Number(g.total_credit).toFixed(2)]);
        sheet.push(['', '', 'Difference', '', Number(g.difference).toFixed(2)]);
        sheet.push([]);
      });

      sheet.push(['', '', 'Grand Total', Number(report.grand.debit).toFixed(2), Number(report.grand.credit).toFixed(2)]);
      sheet.push(['', '', 'Difference', '', Number(report.grand.difference).toFixed(2)]);

      const wb = XLSX.utils.book_new();
      const ws = XLSX.utils.aoa_to_sheet(sheet);
      XLSX.utils.book_append_sheet(wb, ws, 'Trial Balance');
      XLSX.writeFile(wb, `Trial_Balance_${report.start_date}_to_${report.end_date}.xlsx`);
    }

    /* ===================== PDF ===================== */
    function exportToPDF() {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();

      doc.setFontSize(12);
      doc.text('Trial Balance', 14, 15);
      doc.text(report.company_code, 200, 15, { align: 'right' });
      doc.text(`${report.start_date} - ${report.end_date}`, 14, 25);

      const body = [];

      report.groups.forEach(g => {
        // Group header
        body.push([{
          content: `${g.group_code} — ${g.group_name}`,
          colSpan: 5,
          styles: { fillColor: [220, 220, 220], fontStyle: 'bold' }
        }]);

        // Accounts
        g.accounts.forEach(a => {
          body.push([
            a.sno,
            a.account_code,
            a.account_name,
            a.debit ? Number(a.debit).toFixed(2) : '',
            a.credit ? Number(a.credit).toFixed(2) : ''
          ]);
        });

        // Group total
        body.push([{
          content: 'Group Total',
          colSpan: 3,
          styles: { fontStyle: 'bold' }
        },
          Number(g.total_debit).toFixed(2),
          Number(g.total_credit).toFixed(2)
        ]);

        body.push([{
          content: 'Difference',
          colSpan: 3,
          styles: { fontStyle: 'bold', textColor: [180, 0, 0] }
        }, '', Number(g.difference).toFixed(2)]);
      });

      // Grand total
      body.push([{
        content: 'Grand Total',
        colSpan: 3,
        styles: { fontStyle: 'bold', fillColor: [50, 50, 50], textColor: [255, 255, 255] }
      },
        Number(report.grand.debit).toFixed(2),
        Number(report.grand.credit).toFixed(2)
      ]);

      body.push([{
        content: 'Difference',
        colSpan: 3,
        styles: { fontStyle: 'bold' }
      }, '', Number(report.grand.difference).toFixed(2)]);

      doc.autoTable({
        head: [['S.No', 'Code', 'Name', 'Debit', 'Credit']],
        body,
        startY: 35,
        theme: 'grid',
        styles: { fontSize: 8 },
        columnStyles: {
          0: { cellWidth: 12 },
          1: { cellWidth: 28 },
          2: { cellWidth: 80 },
          3: { cellWidth: 30, halign: 'right' },
          4: { cellWidth: 30, halign: 'right' }
        }
      });

      window.open(doc.output('bloburl'));
    }
  </script>
</body>
</html>