<!DOCTYPE html>
<html>
<head>
  <title>Daily Posting</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <style>th, td { font-size: 14px; }</style>
</head>
<body class="container mt-4">

  <div class="d-flex align-items-center gap-3 mb-3">
  <h4 class="mb-0">📋 Daily Posting</h4>
  <input type="text" id="dateInput" class="form-control" style="width:160px;">
</div>

  <% if (entries.length === 0) { %>
    <div class="alert alert-info">No entries found for this date.</div>
  <% } else { %>

  <table class="table table-bordered table-sm">
  <thead class="table-light">
    <tr>
      <th>S.No</th>
      <th>Date</th>
      <th>Voucher</th>
      <th>Account</th>
      <th>Description</th>
      <th>Cash / Bank</th>
      <th class="text-end">Debit</th>
      <th class="text-end">Credit</th>
    </tr>
  </thead>
  <tbody>
    <%
      let grandDebit = 0, grandCredit = 0;
      entries.forEach((e, i) => {
        grandDebit  += e.debit;
        grandCredit += e.credit;
    %>
    <tr>
      <td><%= i + 1 %></td>
      <td><%= e.formatted_date %></td>
      <td><%= e.voucher_no %></td>
      <td><%= e.account_code %> - <%= e.account_name %></td>
      <td><%= e.description || '-' %></td>
      <td><%= e.cash_code %> - <%= e.cash_name %></td>
      <td class="text-end"><%= e.debit  ? fmt(e.debit)  : '' %></td>
      <td class="text-end"><%= e.credit ? fmt(e.credit) : '' %></td>
    </tr>
    <% }) %>

    <tr class="fw-bold table-dark">
      <td colspan="6" class="text-end">Grand Total</td>
      <td class="text-end"><%= fmt(grandDebit) %></td>
      <td class="text-end"><%= fmt(grandCredit) %></td>
    </tr>
  </tbody>
</table>

  <% } %>

  <script>
  // YYYY-MM-DD ko tod ke Date object banao
  const parts = "<%= selectedDate %>".split('-');
  const parsedDate = new Date(parts[0], parts[1] - 1, parts[2]);

  const picker = flatpickr("#dateInput", {
    dateFormat: "d-m-Y",
    allowInput: true,
    defaultDate: parsedDate,  // 👈 string nahi, Date object
    onChange: function(selectedDates) {
      if (!selectedDates[0]) return;
      const d    = selectedDates[0];
      const yyyy = d.getFullYear();
      const mm   = String(d.getMonth() + 1).padStart(2, '0');
      const dd   = String(d.getDate()).padStart(2, '0');
      window.location.href = `/daily-posting?date=${yyyy}-${mm}-${dd}`;
    }
  });
</script>

</body>
</html>