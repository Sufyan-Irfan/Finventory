<!DOCTYPE html>
<html>
<head>
  <title>Cash Book - Filter</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>
<body>
  <div class="container mt-4">
    <h3>🧾 Cash Book</h3>
    <form method="POST" action="/cash-book-result" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label">From (Start Date)</label>
        <input type="text" id="start_date" name="start_date" class="form-control" required>
      </div>

      <div class="col-md-4">
        <label class="form-label">To (End Date)</label>
        <input type="text" id="end_date" name="end_date" class="form-control" required>
      </div>

      <!-- <div class="col-md-4">
        <label class="form-label">Cash Account (company)</label>
        <div class="form-control bg-light"><%= company_code %></div>
        <small class="text-muted">Using company settings cash account code.</small>
      </div> -->

      <div class="col-12">
        <button class="btn btn-primary">Display Cash Book</button>
      </div>
    </form>
  </div>

<script>
  const startPicker = flatpickr("#start_date", { dateFormat: "d-m-Y", allowInput:true });
  const endPicker   = flatpickr("#end_date",   { dateFormat: "d-m-Y", allowInput:true });

  // defaults: start = 1st of current month, end = today
  const now = new Date();
  const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
  startPicker.setDate(firstOfMonth);
  endPicker.setDate(now);
</script>
</body>
</html>
