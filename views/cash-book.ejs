<!DOCTYPE html>
<html>
<head>
  <title>Cash Book - Filter</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>
<body>
  <div class="container mt-4 px-3">
    <h3>🧾 Cash Book</h3>
    <form method="POST" action="/cash-book-result" class="row g-3 align-items-end">
      <div class="col-12 col-sm-6 col-md-4">
        <label class="form-label">From (Start Date)</label>
        <input type="text" id="start_date" name="start_date" class="form-control" required>
      </div>

      <div class="col-12 col-sm-6 col-md-4">
        <label class="form-label">To (End Date)</label>
        <input type="text" id="end_date" name="end_date" class="form-control" required>
      </div>

        <input type="hidden" name="cash_account" value="<%= company_code %>">
<!-- <div class="col-md-4">
        <label class="form-label">Cash Account (company)</label>
        <div class="form-control bg-light"><%= company_code %></div>
        <small class="text-muted">Using company settings cash account code.</small>
      </div> -->

      <div class="col-12">
        <button class="btn btn-primary">Display Cash Book</button>
      </div>
    </form>
  </div>

<script>
  const startInput = flatpickr("#start_date", {
    dateFormat: "d-m-Y",
    allowInput: true
  });
  const endInput = flatpickr("#end_date", {
    dateFormat: "d-m-Y",
    allowInput: true
  });

  startInput.setDate(new Date(2000, 0, 1));   // 01-01-2000
  endInput.setDate(new Date(9999, 11, 31));   // 31-12-9999
</script>
</body>
</html>
