<!DOCTYPE html>
<html>

<head>
  <title>Report Filter</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
</head>

<body>
  <div class="container mt-4 px-3">
    <h3>🔍 Filter GL Account Transactions</h3>
    <form method="POST" action="/report-result" class="row g-3">

      <div class="col-12 col-sm-6">
        <label>Start Date:</label>
        <input type="text" id="start_date" name="start_date" class="form-control" required>
      </div>

      <div class="col-12 col-sm-6">
        <label>End Date:</label>
        <input type="text" id="end_date" name="end_date" class="form-control" required>
      </div>

      <!-- ACCOUNT SEARCH -->
      <!-- FROM ACCOUNT -->
<div class="col-12 col-sm-6" style="position:relative;">
  <label>From Account: <span class="text-danger">*</span></label>
  <input type="text" id="fromSearch" class="form-control" placeholder="Type code or name..." autocomplete="off">
  <input type="hidden" id="from_account" name="from_account" required>
  <div id="fromDropdown" style="position:absolute; z-index:9999; background:#fff; border:1px solid #ccc; border-radius:4px; max-height:220px; overflow-y:auto; width:100%; display:none;"></div>
</div>

<!-- TO ACCOUNT -->
<div class="col-12 col-sm-6" style="position:relative;">
  <label>To Account:</label>
  <input type="text" id="toSearch" class="form-control" placeholder="Type code or name..." autocomplete="off">
  <input type="hidden" id="to_account" name="to_account">
  <div id="toDropdown" style="position:absolute; z-index:9999; background:#fff; border:1px solid #ccc; border-radius:4px; max-height:220px; overflow-y:auto; width:100%; display:none;"></div>
</div>

      <div class="col-12 col-sm-6 col-md-3">
        <label class="form-label">Entry Type</label>
        <select name="entry_type" id="entry_type" class="form-select">
          <option value="ALL">All</option>
          <% entryTypes.forEach(t => { %>
            <option value="<%= t.entry_type %>"><%= t.entry_type %></option>
          <% }) %>
        </select>
      </div>

      <div class="col-12">
        <button type="submit" class="btn btn-primary">Display Report</button>
      </div>

    </form>
  </div>

  <script>
  // ================= DATES =================
  const startInput = flatpickr("#start_date", { dateFormat: "d-m-Y", allowInput: true });
  const endInput   = flatpickr("#end_date",   { dateFormat: "d-m-Y", allowInput: true });
  startInput.setDate(new Date(2000, 0, 1));
  endInput.setDate(new Date(9999, 11, 31));

  // ================= ACCOUNTS DATA =================
  const allAccounts = [
    <% accounts.forEach((a, i) => { %>
      { code: "<%= a.account_code %>", name: "<%- a.name.replace(/"/g, '&quot;') %>", label: "<%= a.account_code %> - <%- a.name.replace(/"/g, '&quot;') %>" }<%= i < accounts.length - 1 ? ',' : '' %>
    <% }) %>
  ];

  // ================= GENERIC SEARCH BUILDER =================
  function buildSearch({ inputId, dropdownId, hiddenId, required, onSelect }) {
    const searchEl  = document.getElementById(inputId);
    const dropEl    = document.getElementById(dropdownId);
    const hiddenEl  = document.getElementById(hiddenId);
    let highlighted = -1;

    function setAccount(a) {
      searchEl.value  = a ? a.label : '';
      hiddenEl.value  = a ? a.code  : '';
      dropEl.style.display = 'none';
      highlighted = -1;
      if (onSelect) onSelect(a);
    }

    function renderDropdown(search) {
      dropEl.innerHTML = '';
      highlighted = -1;

      const filtered = search
        ? allAccounts.filter(a =>
            a.code.toLowerCase().includes(search) ||
            a.name.toLowerCase().includes(search)
          ).slice(0, 50)
        : allAccounts.slice(0, 50);

      if (!filtered.length) { dropEl.style.display = 'none'; return; }

      filtered.forEach((a, i) => {
        const div = document.createElement('div');
        div.textContent = a.label;
        div.style.cssText = 'padding:8px 12px; cursor:pointer; border-bottom:1px solid #eee; font-size:14px;';
        div.addEventListener('mouseenter', () => { highlighted = i; updateHL(); });
        div.addEventListener('mousedown', e => { e.preventDefault(); setAccount(a); });
        dropEl.appendChild(div);
      });

      dropEl._filtered = filtered;
      dropEl.style.display = 'block';
    }

    function updateHL() {
      const items = dropEl.querySelectorAll('div');
      items.forEach((el, i) => el.style.background = i === highlighted ? '#d0e8ff' : '#fff');
      if (items[highlighted]) items[highlighted].scrollIntoView({ block: 'nearest' });
    }

    searchEl.addEventListener('input', function() {
      hiddenEl.value = '';
      renderDropdown(this.value.toLowerCase());
    });

    searchEl.addEventListener('keydown', function(e) {
      const items = dropEl._filtered || [];
      if (!items.length) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); highlighted = Math.min(highlighted+1, items.length-1); updateHL(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); highlighted = Math.max(highlighted-1, 0); updateHL(); }
      else if (e.key === 'Enter') { e.preventDefault(); if (highlighted >= 0) setAccount(items[highlighted]); }
      else if (e.key === 'Escape') dropEl.style.display = 'none';
    });

    searchEl.addEventListener('blur', () => setTimeout(() => dropEl.style.display = 'none', 200));
    searchEl.addEventListener('focus', function() { this.select(); renderDropdown(this.value.toLowerCase()); });

    return { setAccount };
  }

  // ================= FROM SEARCH =================
  const fromSearch = buildSearch({
    inputId: 'fromSearch', dropdownId: 'fromDropdown', hiddenId: 'from_account',
    required: true,
    onSelect: (a) => {
      // From select hote hi To mein auto-fill
      if (a) toSearch.setAccount(a);
    }
  });

  // ================= TO SEARCH =================
  const toSearch = buildSearch({
    inputId: 'toSearch', dropdownId: 'toDropdown', hiddenId: 'to_account',
    required: false
  });

  // ================= FORM VALIDATION =================
  document.querySelector('form').addEventListener('submit', function(e) {
    const fromVal = document.getElementById('from_account').value;
    if (!fromVal) {
      e.preventDefault();
      document.getElementById('fromSearch').focus();
      document.getElementById('fromSearch').style.borderColor = 'red';
      alert('Please select From Account!');
    }
  });
</script>

</body>

</html>