<!DOCTYPE html>
<html>

<head>
  <title>Ledger Report</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="container mt-4">

  <h4>
    Ledger :
    <%= party.name %>
  </h4>
  <p>From <strong>
      <%= start_date %>
    </strong> to <strong>
      <%= end_date %>
    </strong></p>

  <div class="mb-3">
    <button onclick="exportPDF()" class="btn btn-outline-dark btn-sm me-2">📄 PDF</button>
    <button onclick="exportExcel()" class="btn btn-outline-success btn-sm">📁 Excel</button>
  </div>

  <table id="ledgerTable" class="table table-bordered table-sm">
    <thead class="table-light">
      <tr>
        <th>Date</th>
        <th>Voucher</th>
        <th>Description</th>
        <th class="text-end">Debit</th>
        <th class="text-end">Credit</th>
        <th class="text-end">Balance</th>
      </tr>
    </thead>
    <tbody>

      <% let balance=Number(party.opening_balance || 0); %>
        <% let totalDebit=0, totalCredit=0; %>

          <tr class="fw-bold">
            <td colspan="5">Opening Balance</td>
            <td class="text-end">
              <%= balance.toFixed(2) %>
            </td>
          </tr>

          <% transactions.forEach(t=> {
            const d = Number(t.debit || 0);
            const c = Number(t.credit || 0);
            balance += d - c;
            totalDebit += d;
            totalCredit += c;
            %>
            <tr>
              <td>
                <%= t.formatted_date %>
              </td>
              <td>
                <%= t.voucher_no || '-' %>
              </td>
              <td>
                <%= t.description || '-' %>
              </td>
              <td class="text-end">
                <%= d ? d.toFixed(2) : '' %>
              </td>
              <td class="text-end">
                <%= c ? c.toFixed(2) : '' %>
              </td>
              <td class="text-end">
                <%= balance.toFixed(2) %>
              </td>
            </tr>
            <% }) %>

              <tr class="fw-bold table-secondary">
                <td colspan="3">TOTAL</td>
                <td class="text-end">
                  <%= totalDebit.toFixed(2) %>
                </td>
                <td class="text-end">
                  <%= totalCredit.toFixed(2) %>
                </td>
                <td class="text-end">
                  <%= balance.toFixed(2) %>
                </td>
              </tr>

    </tbody>
  </table>

  <a href="/report">← Back</a>

  <!-- LIBS -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

<script>
const report = <%- JSON.stringify({ party, transactions }) %>;

// ================= EXCEL =================
function exportExcel() {
  const data = [
    ['Date', 'Voucher', 'Description', 'Debit', 'Credit', 'Balance']
  ];

  let bal = Number(report.party.opening_balance || 0);
  let totalDebit = 0;
  let totalCredit = 0;

  data.push(['', '', 'Opening Balance', '', '', bal]);

  report.transactions.forEach(t => {
    const d = Number(t.debit || 0);
    const c = Number(t.credit || 0);

    totalDebit += d;
    totalCredit += c;
    bal += d - c;

    data.push([
      t.formatted_date,
      t.voucher_no || '',
      t.description || '',
      d,
      c,
      bal
    ]);
  });

  // ✅ TOTAL
  data.push(['', '', 'TOTAL', totalDebit, totalCredit, bal]);

  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet(data);
  XLSX.utils.book_append_sheet(wb, ws, 'Ledger');
  XLSX.writeFile(wb, 'ledger.xlsx');
}

// ================= PDF =================
function exportPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF('p', 'pt', 'a4');

  doc.setFontSize(12);
  doc.text(`Ledger: ${report.party.name}`, 40, 30);

  let bal = Number(report.party.opening_balance || 0);
  let totalDebit = 0;
  let totalCredit = 0;

  const rows = [];

  rows.push(['', '', 'Opening Balance', '', '', bal.toFixed(2)]);

  report.transactions.forEach(t => {
    const d = Number(t.debit || 0);
    const c = Number(t.credit || 0);

    totalDebit += d;
    totalCredit += c;
    bal += d - c;

    rows.push([
      t.formatted_date,
      t.voucher_no || '',
      t.description || '',
      d ? d.toFixed(2) : '',
      c ? c.toFixed(2) : '',
      bal.toFixed(2)
    ]);
  });

  // ✅ TOTAL ROW
  rows.push([
    '', '', 'TOTAL',
    totalDebit.toFixed(2),
    totalCredit.toFixed(2),
    bal.toFixed(2)
  ]);

  doc.autoTable({
    head: [['Date', 'Voucher', 'Description', 'Debit', 'Credit', 'Balance']],
    body: rows,
    startY: 50
  });

  window.open(doc.output('bloburl'), '_blank');
}
</script>

</body>

</html>