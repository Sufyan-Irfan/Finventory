<div class="container mt-4">
  <h2 class="mb-4">✏️ Edit Voucher – <%= voucher_no %>
  </h2>

  <% entries.forEach(row=> { %>
    <form method="POST" action="/gl/edit-transaction/<%= voucher_no %>?query=<%= query %>"
      class="border rounded p-3 mb-4 bg-light">

      <div class="row g-3">

        <!-- Date -->
        <div class="col-md-3">
          <label class="form-label">Date</label>
          <input type="date" name="date" value="<%= new Date(row.date).toISOString().split('T')[0] %>" required
            class="form-control">
        </div>

        <!-- Voucher No -->
        <div class="col-md-3">
          <label class="form-label">Voucher No</label>
          <input type="text" value="<%= voucher_no %>" readonly class="form-control bg-light">
        </div>

        <!-- Serial -->
        <div class="col-md-3">
          <label class="form-label">Serial No</label>
          <input type="text" name="serial_no" value="<%= row.serial_no || '' %>" class="form-control">
        </div>

        <!-- Entry Type -->
        <div class="col-md-3">
          <label class="form-label">Entry Type</label>
          <input type="text" value="<%= row.entry_type %>" readonly class="form-control bg-light">
        </div>

        <!-- Account -->
        <div class="col-md-6">
          <label class="form-label">Account</label>
          <select name="account_code" class="form-select" required>
            <% accounts.forEach(a=> { %>
              <option value="<%= a.account_code %>" <%=a.account_code===row.account_code ? 'selected' : '' %>>
                <%= a.account_code %> – <%= a.name %>
              </option>
              <% }) %>
          </select>
        </div>

        <!-- Narration -->
        <div class="col-md-6">
          <label class="form-label">Narration</label>
          <input type="text" name="description" value="<%= row.description || '' %>" class="form-control">
        </div>

        <!-- Reference -->
        <div class="col-md-4">
          <label class="form-label">Reference</label>
          <input type="text" name="reference" value="<%= row.reference || '' %>" class="form-control">
        </div>

        <!-- Invoice -->
        <div class="col-md-4">
          <label class="form-label">Invoice</label>
          <input type="text" name="invoice" value="<%= row.invoice || '' %>" class="form-control">
        </div>

        <!-- Debit -->
        <div class="col-md-2">
          <label class="form-label">Debit</label>
          <input type="number" step="0.01" name="debit" value="<%= row.debit || '' %>" class="form-control">
        </div>

        <!-- Credit -->
        <div class="col-md-2">
          <label class="form-label">Credit</label>
          <input type="number" step="0.01" name="credit" value="<%= row.credit || '' %>" class="form-control">
        </div>

      </div>

      <div class="mt-3 d-flex justify-content-between">
        <button type="submit" class="btn btn-success">
          💾 Update Entry
        </button>

        <form method="POST" action="/gl/delete-voucher/<%= voucher_no %>"
          onsubmit="return confirm('Delete this entry?')">
          <button type="submit" class="btn btn-danger">
            🗑 Delete
          </button>
        </form>
      </div>

    </form>
    <% }) %>

      <a href="/search?query=<%= query %>" class="btn btn-secondary">
        ← Back to Search
      </a>
</div>