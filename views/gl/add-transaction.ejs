<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0">
        <%= editData ? 'Edit ' + (voucher_type==='PV' ? 'Cash Payment Voucher' : 'Cash Receipt Voucher') :
          (voucher_type==='PV' ? 'Cash Payment Voucher' : 'Cash Receipt Voucher') %>
      </h5>
    </div>

    <div class="card-body">
      <div id="alertBox"></div>

      <form id="transactionForm">
        <input type="hidden" name="entry_type"   value="<%= entry_type %>">
        <input type="hidden" name="voucher_type" value="<%= voucher_type %>">
        <input type="hidden" name="is_edit"      value="<%= editData ? 1 : 0 %>">
        <input type="hidden" name="date"         id="date">
        <input type="hidden" name="cash_account" id="cash_account">

        <div class="row g-3">

          <div class="col-md-4">
            <label class="form-label">Date</label>
            <input type="text" id="date_display" class="form-control" required>
          </div>

          <div class="col-md-4">
            <label class="form-label">Voucher No</label>
            <input type="text" id="voucher_no" name="voucher_no" class="form-control bg-light" readonly
              value="<%= editData ? editData.voucher_no : '' %>">
          </div>

          <div class="col-md-4">
            <label class="form-label">Serial No</label>
            <input type="text" name="serial_no" class="form-control"
              value="<%= editData ? editData.serial_no : '' %>">
          </div>

          <!-- PARTY ACCOUNT SEARCH -->
          <div class="col-md-6" style="position:relative;">
            <label class="form-label">Account</label>
            <input type="text" id="accountSearch" class="form-control"
                   placeholder="Type code or name..." autocomplete="off">
            <input type="hidden" id="account_code" name="account_code" required>
            <div id="accountDropdown"
                 style="position:absolute;z-index:9999;background:#fff;border:1px solid #ccc;
                        border-radius:4px;max-height:200px;overflow-y:auto;width:100%;display:none;">
            </div>
          </div>

          <div class="col-md-6">
            <label class="form-label">Account Balance</label>
            <input type="text" id="accountBalance" class="form-control bg-light" readonly value="0.00">
          </div>

          <div class="col-md-12">
            <label class="form-label">Narration</label>
            <input type="text" name="description" class="form-control"
              value="<%= editData ? editData.description || '' : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Reference</label>
            <input type="text" name="reference" class="form-control"
              value="<%= editData ? editData.reference || '' : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Invoice</label>
            <input type="text" name="invoice" class="form-control"
              value="<%= editData ? editData.invoice || '' : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Amount</label>
            <input type="number" name="amount" step="0.01" class="form-control" required
              value="<%= editData ? editData.amount : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Batch Total</label>
            <input type="text" id="batch_total" class="form-control bg-light" readonly
              value="<%= editData ? editData.amount : '0.00' %>">
          </div>

          <!-- CASH / BANK ACCOUNT SEARCH -->
          <div class="col-md-6" style="position:relative;">
            <label class="form-label">
              Cash / Bank Account
              <small class="text-muted">(default: company cash)</small>
            </label>
            <input type="text" id="cashSearch" class="form-control"
                   placeholder="Type code or name..." autocomplete="off">
            <div id="cashDropdown"
                 style="position:absolute;z-index:9999;background:#fff;border:1px solid #ccc;
                        border-radius:4px;max-height:200px;overflow-y:auto;width:100%;display:none;">
            </div>
          </div>

          <div class="col-md-6">
            <label class="form-label">Cash / Bank Balance</label>
            <input type="text" id="cashInHand" class="form-control bg-light" readonly value="0.00">
          </div>

        </div>

        <div class="mt-4 text-end">
          <button type="button" id="saveBtn" class="btn btn-success px-4">
            <%= editData ? 'Update Transaction' : 'Save Transaction' %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
$(document).ready(function () {

  // ── Server se values ──────────────────────────────────────
  const isEdit          = <%= editData ? 'true' : 'false' %>;
  const editDate        = "<%= editData ? editData.date         : '' %>".trim();
  const editAccount     = "<%= editData ? editData.account_code  : '' %>".trim();
  const editCashCode    = "<%= editData ? (editData.cash_account || '') : '' %>".trim();
  const editAmount      = "<%= editData ? editData.amount       : '' %>".trim();
  const defaultCashCode = "<%= settings ? settings.cash_account_code : '' %>".trim();
  const voucherType     = "<%= voucher_type %>";

  // ── Accounts array — codes trim karke store karo ─────────
  const allAccounts = [];
  <% accounts.forEach(function(a) { %>
    allAccounts.push({
      code:  "<%= a.account_code %>".trim(),
      name:  `<%- a.name.replace(/`/g, "'") %>`.trim(),
      label: "<%= a.account_code %>".trim() + " - " + `<%- a.name.replace(/`/g, "'") %>`.trim()
    });
  <% }); %>

  // ── Date ──────────────────────────────────────────────────
  function formatToDB(d) {
    return d.getFullYear() + "-" +
      String(d.getMonth() + 1).padStart(2, "0") + "-" +
      String(d.getDate()).padStart(2, "0");
  }

  let initialDate;
  if (isEdit && editDate) {
    const parts = editDate.slice(0, 10).split("-");
    initialDate = new Date(+parts[0], +parts[1] - 1, +parts[2]);
    $("#date").val(editDate.slice(0, 10));
  } else {
    initialDate = new Date();
    $("#date").val(formatToDB(initialDate));
  }

  flatpickr("#date_display", {
    dateFormat: "d-m-Y",
    defaultDate: initialDate,
    allowInput: true,
    onChange(sel) { if (sel.length) $("#date").val(formatToDB(sel[0])); }
  });

  // ── Voucher no ────────────────────────────────────────────
  if (!isEdit) {
    fetch(`/api/next-voucher?voucher_type=${voucherType}`)
      .then(r => r.json())
      .then(d => { if (d.success) $("#voucher_no").val(d.voucher_no); });
  }

  // ── Balance fetch ─────────────────────────────────────────
  async function fetchBalance(code, sel) {
    if (!code) { $(sel).val("0.00"); return; }
    try {
      const d = await fetch(`/api/account-balance/${code}`).then(r => r.json());
      $(sel).val(parseFloat(d.balance || 0).toLocaleString('en-PK', { minimumFractionDigits: 2 }));
    } catch { $(sel).val("0.00"); }
  }

  // ── Dropdown factory ──────────────────────────────────────
  function makeDropdown(searchId, dropdownId, hiddenId, onSelect) {
    const searchEl   = document.getElementById(searchId);
    const dropdownEl = document.getElementById(dropdownId);
    const hiddenEl   = document.getElementById(hiddenId);
    let hi = -1;

    function pick(a) {
      searchEl.value = a.label;
      hiddenEl.value = a.code;
      dropdownEl.style.display = 'none';
      hi = -1;
      if (onSelect) onSelect(a);
    }

    function render(q) {
      dropdownEl.innerHTML = '';
      hi = -1;
      const list = q
        ? allAccounts.filter(a => a.code.includes(q) || a.name.toLowerCase().includes(q)).slice(0, 50)
        : allAccounts.slice(0, 50);
      dropdownEl._list = list;
      if (!list.length) { dropdownEl.style.display = 'none'; return; }
      list.forEach((a, i) => {
        const d = document.createElement('div');
        d.textContent = a.label;
        d.style.cssText = 'padding:8px 12px;cursor:pointer;border-bottom:1px solid #eee;font-size:14px;';
        d.onmouseenter = () => { hi = i; hl(); };
        d.onmousedown  = e => { e.preventDefault(); pick(a); };
        dropdownEl.appendChild(d);
      });
      dropdownEl.style.display = 'block';
    }

    function hl() {
      dropdownEl.querySelectorAll('div').forEach((el, i) => {
        el.style.background = i === hi ? '#d0e8ff' : '#fff';
      });
      const el = dropdownEl.querySelectorAll('div')[hi];
      if (el) el.scrollIntoView({ block: 'nearest' });
    }

    searchEl.addEventListener('input', function () {
      hiddenEl.value = '';
      render(this.value.toLowerCase().trim());
    });
    searchEl.addEventListener('keydown', function (e) {
      const list = dropdownEl._list || [];
      if (e.key === 'ArrowDown')  { e.preventDefault(); hi = Math.min(hi+1, list.length-1); hl(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); hi = Math.max(hi-1, 0); hl(); }
      else if (e.key === 'Enter')   { e.preventDefault(); if (hi >= 0 && list[hi]) pick(list[hi]); }
      else if (e.key === 'Escape')  { dropdownEl.style.display = 'none'; }
    });
    searchEl.addEventListener('blur',  ()  => setTimeout(() => dropdownEl.style.display = 'none', 200));
    searchEl.addEventListener('focus', function () { render(this.value.toLowerCase().trim()); });

    // ── setByCode: trim karke match karo ──────────────────
    function setByCode(code) {
  const c = String(code).trim();
  const found = allAccounts.find(a => a.code === c);
  if (found) {
    searchEl.value = found.label;
    hiddenEl.value = found.code;
    if (onSelect) onSelect(found);  // ← yeh line add karo
  } else {
    searchEl.value = c;
    hiddenEl.value = c;
  }
}

    return { setByCode, pick };
  }

  // ── Dropdowns banao ───────────────────────────────────────
  const partyDD = makeDropdown(
    'accountSearch', 'accountDropdown', 'account_code',
    a => fetchBalance(a.code, '#accountBalance')
  );

  const cashDD = makeDropdown(
    'cashSearch', 'cashDropdown', 'cash_account',
    a => fetchBalance(a.code, '#cashInHand')
  );

  // ── PRE-FILL — yahi asli fix hai ─────────────────────────
  if (isEdit) {
    if (editAccount) {
      partyDD.setByCode(editAccount);
      fetchBalance(editAccount, '#accountBalance');
    }
    const cashToSet = editCashCode || defaultCashCode;
    if (cashToSet) {
      cashDD.setByCode(cashToSet);
      fetchBalance(cashToSet, '#cashInHand');
    }
  } else {
    if (defaultCashCode) {
      cashDD.setByCode(defaultCashCode);
      fetchBalance(defaultCashCode, '#cashInHand');
    }
  }

  // ── Amount ────────────────────────────────────────────────
  if (isEdit && editAmount) {
    const amt = parseFloat(editAmount);
    if (!isNaN(amt)) {
      $("input[name='amount']").val(amt);
      $("#batch_total").val(amt.toFixed(2));
    }
  }
  $("input[name='amount']").on("input", function () {
    $("#batch_total").val((parseFloat(this.value) || 0).toFixed(2));
  });

  // ── Save ──────────────────────────────────────────────────
  $("#saveBtn").click(async function () {
    const data = Object.fromEntries(new FormData(document.getElementById('transactionForm')));

    // ── Debug: console mein check karo ke values aa rahi hain
    console.log("account_code:", data.account_code);
    console.log("cash_account:", data.cash_account);

    if (!data.account_code || !data.account_code.trim()) {
      $("#alertBox").html('<div class="alert alert-danger">Please select an account!</div>');
      return;
    }
    if (!data.cash_account || !data.cash_account.trim()) {
      data.cash_account = defaultCashCode;
    }

    try {
      const res = await fetch("/gl/add-transaction", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });
      const r = await res.json();
      $("#alertBox").html(`<div class="alert alert-${r.success ? 'success' : 'danger'}">${r.message}</div>`);
      if (r.success) {
        setTimeout(() => { window.location.href = `/search?query=${data.voucher_no}&message=Updated`; }, 1500);
      }
    } catch {
      $("#alertBox").html('<div class="alert alert-danger">Network error. Try again.</div>');
    }
  });

});
</script>

