<div class="container mt-4">
  <div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0">
        <%= editData ? 'Edit ' + (voucher_type==='PV' ? 'Cash Payment Voucher' : 'Cash Receipt Voucher' ) :
          (voucher_type==='PV' ? 'Cash Payment Voucher' : 'Cash Receipt Voucher' ) %>
      </h5>
    </div>

    <div class="card-body">
      <div id="alertBox"></div>

      <form id="transactionForm">
        <input type="hidden" name="entry_type" value="<%= entry_type %>">
        <input type="hidden" name="voucher_type" value="<%= voucher_type %>">
        <input type="hidden" name="is_edit" value="<%= editData ? 1 : 0 %>">
        <input type="hidden" name="date" id="date">
        <input type="hidden" name="cash_account" id="cash_account">

        <div class="row g-3">

          <div class="col-md-4">
            <label class="form-label">Date</label>
            <input type="text" id="date_display" class="form-control" required>
          </div>

          <div class="col-md-4">
            <label class="form-label">Voucher No</label>
            <input type="text" id="voucher_no" name="voucher_no" class="form-control bg-light" readonly
              value="<%= editData ? editData.voucher_no : '' %>">
          </div>

          <div class="col-md-4">
            <label class="form-label">Serial No</label>
            <input type="text" name="serial_no" class="form-control" value="<%= editData ? editData.serial_no : '' %>">
          </div>

          <!-- PARTY ACCOUNT SEARCH -->
          <div class="col-md-6" style="position:relative;">
            <label class="form-label">Account</label>
            <input type="text" id="accountSearch" class="form-control" placeholder="Type code or name..." autocomplete="off">
            <input type="hidden" id="account_code" name="account_code" required>
            <div id="accountDropdown" style="position:absolute; z-index:9999; background:#fff; border:1px solid #ccc; border-radius:4px; max-height:200px; overflow-y:auto; width:100%; display:none;"></div>
          </div>

          <div class="col-md-6">
            <label class="form-label">Account Balance</label>
            <input type="text" id="accountBalance" class="form-control bg-light" readonly value="0.00">
          </div>

          <div class="col-md-12">
            <label class="form-label">Narration</label>
            <input type="text" name="description" class="form-control" value="<%= editData ? editData.description : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Reference</label>
            <input type="text" name="reference" class="form-control" value="<%= editData ? editData.reference : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Invoice</label>
            <input type="text" name="invoice" class="form-control" value="<%= editData ? editData.invoice : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Amount</label>
            <input type="number" name="amount" step="0.01" class="form-control" required
              value="<%= editData ? editData.amount : '' %>">
          </div>

          <div class="col-md-6">
            <label class="form-label">Batch Total</label>
            <input type="text" id="batch_total" class="form-control bg-light" readonly
              value="<%= editData ? editData.amount : '0.00' %>">
          </div>

          <!-- CASH ACCOUNT SEARCH -->
          <div class="col-md-6" style="position:relative;">
            <label class="form-label">Cash / Bank Account <small class="text-muted">(default: company cash)</small></label>
            <input type="text" id="cashSearch" class="form-control" placeholder="Type code or name..." autocomplete="off">
            <div id="cashDropdown" style="position:absolute; z-index:9999; background:#fff; border:1px solid #ccc; border-radius:4px; max-height:200px; overflow-y:auto; width:100%; display:none;"></div>
          </div>

          <div class="col-md-6">
            <label class="form-label">Cash / Bank Balance</label>
            <input type="text" id="cashInHand" class="form-control bg-light" readonly value="0.00">
          </div>

        </div>

        <div class="mt-4 text-end">
          <button type="button" id="saveBtn" class="btn btn-success px-4">
            <%= editData ? 'Update Transaction' : 'Save Transaction' %>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
$(document).ready(function () {

  const isEdit = <%= editData ? 'true' : 'false' %>;
  const editDate = "<%= editData ? editData.date : '' %>";
  const editAccount = "<%= editData ? editData.account_code : '' %>";
  const editAmount = "<%= editData ? editData.amount : '' %>";
  const defaultCashCode = "<%= settings.cash_account_code %>";
  const editCashCode = "<%= editData ? (editData.cash_account || '') : '' %>";
  const voucherType = "<%= voucher_type %>";

  // ================= ALL ACCOUNTS LIST =================
  const allAccounts = [
    <% accounts.forEach((a, i) => { %>
      { code: "<%= a.account_code %>", name: "<%- a.name.replace(/"/g, '&quot;') %>", label: "<%= a.account_code %> - <%- a.name.replace(/"/g, '&quot;') %>" }<%= i < accounts.length - 1 ? ',' : '' %>
    <% }) %>
  ];

  // ================= DATE =================
  function formatToDB(dateObj) {
    return dateObj.getFullYear() + "-" +
      String(dateObj.getMonth() + 1).padStart(2, "0") + "-" +
      String(dateObj.getDate()).padStart(2, "0");
  }

  let initialDate;
  if (isEdit && editDate) {
    const parts = editDate.toString().slice(0, 10).split("-");
    initialDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
    $("#date").val(parts.join("-"));
  } else {
    initialDate = new Date();
    $("#date").val(formatToDB(initialDate));
  }

  flatpickr("#date_display", {
    dateFormat: "d-m-Y",
    defaultDate: initialDate,
    allowInput: true,
    onChange: function (selectedDates) {
      if (selectedDates.length) $("#date").val(formatToDB(selectedDates[0]));
    }
  });

  // ================= VOUCHER =================
  if (!isEdit) {
    fetch(`/api/next-voucher?voucher_type=${voucherType}`)
      .then(r => r.json())
      .then(d => { if (d.success) $("#voucher_no").val(d.voucher_no); });
  }

  // ================= BALANCE FETCH =================
  async function fetchBalance(code, target) {
    if (!code) return $(target).val("0.00");
    try {
      const r = await fetch(`/api/account-balance/${code}`);
      const d = await r.json();
      $(target).val(d.balance || "0.00");
    } catch {
      $(target).val("0.00");
    }
  }

  // ================= GENERIC DROPDOWN MAKER =================
  function makeDropdown(searchEl, dropdownEl, hiddenEl, onSelect) {
    let highlightedIndex = -1;

    function setItem(a) {
      searchEl.value = a.label;
      if (hiddenEl) hiddenEl.value = a.code;
      dropdownEl.style.display = 'none';
      highlightedIndex = -1;
      if (onSelect) onSelect(a);
    }

    function renderDropdown(search) {
      dropdownEl.innerHTML = '';
      highlightedIndex = -1;

      const filtered = search
        ? allAccounts.filter(a =>
            a.code.toLowerCase().includes(search) ||
            a.name.toLowerCase().includes(search)
          ).slice(0, 50)
        : allAccounts.slice(0, 50);

      if (filtered.length === 0) {
        dropdownEl.style.display = 'none';
        return;
      }

      filtered.forEach((a, i) => {
        const div = document.createElement('div');
        div.textContent = a.label;
        div.style.cssText = 'padding:8px 12px; cursor:pointer; border-bottom:1px solid #eee; font-size:14px;';
        div.addEventListener('mouseenter', () => { highlightedIndex = i; updateHighlight(); });
        div.addEventListener('mousedown', (e) => { e.preventDefault(); setItem(a); });
        dropdownEl.appendChild(div);
      });

      dropdownEl._filtered = filtered;
      dropdownEl.style.display = 'block';
    }

    function updateHighlight() {
      const items = dropdownEl.querySelectorAll('div');
      items.forEach((el, i) => {
        el.style.background = i === highlightedIndex ? '#d0e8ff' : '#fff';
      });
      if (items[highlightedIndex]) items[highlightedIndex].scrollIntoView({ block: 'nearest' });
    }

    searchEl.addEventListener('input', function() {
      if (hiddenEl) hiddenEl.value = '';
      renderDropdown(this.value.toLowerCase());
    });

    searchEl.addEventListener('keydown', function(e) {
      const items = dropdownEl._filtered || [];
      if (!items.length) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); highlightedIndex = Math.min(highlightedIndex + 1, items.length - 1); updateHighlight(); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); highlightedIndex = Math.max(highlightedIndex - 1, 0); updateHighlight(); }
      else if (e.key === 'Enter') { e.preventDefault(); if (highlightedIndex >= 0 && items[highlightedIndex]) setItem(items[highlightedIndex]); }
      else if (e.key === 'Escape') { dropdownEl.style.display = 'none'; }
    });

    searchEl.addEventListener('blur', () => { setTimeout(() => dropdownEl.style.display = 'none', 200); });
    searchEl.addEventListener('focus', function() { renderDropdown(this.value.toLowerCase()); });

    return { setByCode: (code) => {
      const found = allAccounts.find(a => a.code === String(code));
      if (found) setItem(found);
    }};
  }

  // ================= PARTY ACCOUNT DROPDOWN =================
  const partyDropdown = makeDropdown(
    document.getElementById('accountSearch'),
    document.getElementById('accountDropdown'),
    document.getElementById('account_code'),
    (a) => fetchBalance(a.code, "#accountBalance")
  );

  if (isEdit && editAccount) {
    partyDropdown.setByCode(editAccount);
    fetchBalance(editAccount, "#accountBalance");
  }

  // ================= CASH ACCOUNT DROPDOWN =================
  const cashDropdown = makeDropdown(
    document.getElementById('cashSearch'),
    document.getElementById('cashDropdown'),
    null, // hidden input alag handle karenge
    (a) => {
      $("#cash_account").val(a.code);
      fetchBalance(a.code, "#cashInHand");
    }
  );

  // Default cash set karo
  const initialCash = (isEdit && editCashCode) ? editCashCode : defaultCashCode;
  if (initialCash) {
    cashDropdown.setByCode(initialCash);
    $("#cash_account").val(initialCash);
    fetchBalance(initialCash, "#cashInHand");
  }

  // ================= AMOUNT =================
  if (isEdit && editAmount) {
    const amt = parseFloat(editAmount);
    if (!isNaN(amt)) {
      $("input[name='amount']").val(amt);
      $("#batch_total").val(amt.toFixed(2));
    }
  }

  $("input[name='amount']").on("input", function () {
    const val = parseFloat(this.value) || 0;
    $("#batch_total").val(val.toFixed(2));
  });

  // ================= SAVE =================
  $("#saveBtn").click(async function () {
    const form = document.getElementById("transactionForm");
    const data = Object.fromEntries(new FormData(form));

    if (!data.account_code) {
      $("#alertBox").html('<div class="alert alert-danger">Please select an account!</div>');
      return;
    }

    if (!data.cash_account) {
      data.cash_account = defaultCashCode;
    }

    const res = await fetch("/gl/add-transaction", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data)
    });

    const r = await res.json();
    $("#alertBox").html(`<div class="alert alert-${r.success ? 'success' : 'danger'}">${r.message}</div>`);

    if (r.success) {
      setTimeout(() => {
        window.location.href = `/search?query=${data.voucher_no}&message=Updated`;
      }, 2000);
    }
  });

});
</script>